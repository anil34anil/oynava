# ── GameMonetize feed ───────────────────────────────────────────────
# gamemonetize.com'a ücretsiz üye ol -> Publisher paneli -> Feed/RSS.
# Kendi publisher feed URL'ini buraya yapıştır (oyun içi reklam geliri sana gelsin).
# Boş bırakırsan public feed kullanılır.
GAMEMONETIZE_FEED_URL=https://gamemonetize.com/feed.php?format=0&num=ALL

# ── GamePix (kaliteli/3D oyun ağı) ──────────────────────────────────
# gamepix.com'a publisher kaydı → kendi "sid" değerini al → buraya yaz.
# Boş bırakılırsa oyunlar yine gelir ama oyun içi reklam geliri sana yazılmaz.
GAMEPIX_SID=

# ── Site ────────────────────────────────────────────────────────────
# Gerçek domainini yaz (sitemap ve robots için kullanılır)
NEXT_PUBLIC_SITE_URL=https://senindomainin.com

# ── Google AdSense ──────────────────────────────────────────────────
# adsense.google.com -> sitenı ekle, onay bekle. Yayıncı kimliğin: ca-pub-XXXX
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# Reklam birimi (slot) kimlikleri — AdSense panelinden oluştur
# Boş bırakılan slotlar geliştirmede "Reklam Alanı" yer tutucusu gösterir.
NEXT_PUBLIC_AD_SLOT_TOP=
NEXT_PUBLIC_AD_SLOT_BOTTOM=
NEXT_PUBLIC_AD_SLOT_LEFT=
NEXT_PUBLIC_AD_SLOT_LEFT2=
NEXT_PUBLIC_AD_SLOT_RIGHT=
NEXT_PUBLIC_AD_SLOT_RIGHT2=
NEXT_PUBLIC_AD_SLOT_SIDEBAR=

# ⚠️ AdSense, içerikten fazla reklam olan sayfaları onaylamaz / hesabı kapatabilir.
# Tüm slotları doldurmak zorunda değilsin; gerektiği kadarını kullan.

# ── Beğeni (like) sistemi — paylaşılan sayaç ────────────────────────
# Vercel proje panelinde Storage → Marketplace → "Redis" (Upstash) ekle;
# Production env değişkenleri (KV_REST_API_URL, KV_REST_API_TOKEN vb.) otomatik
# eklenir. Lokalde denemek için: `vercel env pull .env.local`.
# Bunlar ayarlanmadan beğeni butonları görünür ama sayaç hep 0 kalır (site çökmez).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Admin paneli (/admin/oylar) ─────────────────────────────────────
# Sadece senin görebileceğin "oylanan oyunlar" panelinin şifresi. Güçlü, kendine
# özel bir şifre seç — bu değer hiçbir yerde gösterilmez, sadece sen bilirsin.
ADMIN_PASSWORD=
